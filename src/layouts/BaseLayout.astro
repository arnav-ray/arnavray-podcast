---
export interface Props {
	title: string;
}

const { title, lang = 'en' } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | ArnavRay Podcast</title>
  <link rel="stylesheet" href="/style.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
        :root {
            --accent: #2337ff;
            --accent-dark: #000d8a;
            --black: 15, 18, 25;
            --white: 255, 255, 255;
            --gray: 96, 115, 159;
            --gray-light: 229, 233, 240;
            --gray-dark: 34, 41, 57;
        }
        html {
            font-family: system-ui, sans-serif;
            background: #13151a;
            color: white;
        }
    </style>
</head>
<body>
  <main>
    <slot />
  </main>
</body>
</html>